# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Google Vertex AI (Imagen — Avatar-Generierung)
GCP_PROJECT=my-gcp-project-id
GCP_LOCATION=us-central1

# Signal
SIGNAL_CLI_URL=http://signal-cli:8080
SIGNAL_PHONE_NUMBER=+43...       # Bot-Nummer (linked device)
ADMIN_PHONE_NUMBER=+43...        # Wer !kommandos schicken darf

# NAS — Pfad zu phieb/ttrpg (Engine, Adventures, Spieler)
TTRPG_PATH=/mnt/ttrpg

# Bot-Verhalten
MAX_CONTEXT_TOKENS=3000          # Max Output-Tokens pro Claude-Antwort
HISTORY_MESSAGES=6               # Wie viele Nachrichten im Kontext bleiben
RESPONSE_DELAY_SECONDS=2         # Kurze Pause vor der Antwort (Tipp-Illusion)

# Rate Limiting (pro Absender)
RATE_LIMIT_MESSAGES=5            # Max Nachrichten…
RATE_LIMIT_WINDOW=60             # …pro X Sekunden

# Nachrichten-Batching
BATCH_WINDOW_SECONDS=60          # Warte X Sekunden bevor der DM antwortet
                                 # (sofort wenn alle Spieler geantwortet haben)

# Log-Rotation
MAX_LOG_LINES=500                # JSONL-Zeilen bis zur automatischen Rotation
